# Copy this file to .env and fill in your real keys.
# .env is gitignored.

# --- Sentiment engine ---
NEWSAPI_KEY=
FINNHUB_KEY=
ALPHAVANTAGE_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sfe/0.1 by yourusername

# --- Quantitative engine ---
# (yfinance needs no key; Polygon is optional)
POLYGON_API_KEY=

# --- Enrichment signals ---
FRED_API_KEY=
UNUSUAL_WHALES_KEY=

# --- Meta-synthesis layer ---
ANTHROPIC_API_KEY=

# --- Storage ---
# SQLite local default. Switch to postgresql://... when migrating.
SFE_DB_URL=sqlite:///./data/sfe.db
